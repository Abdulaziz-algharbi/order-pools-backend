{
  "name": "order-pools-backend",
  "version": "1.0.0",
  "description": "lets many buyers pool their orders together to buy goods in bulk. This acts like a wholesale buying club. The larger order size unlocks big discounts. This lowers costs for everyone",
  "main": "index.js",
  "scripts": {
    "build": "npx tsc",
    "start": "node ./dist/app.js",
    "dev": "ts-node-dev --files --respawn src/server.ts",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Abdulaziz-algharbi/order-pools-backend.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Abdulaziz-algharbi/order-pools-backend/issues"
  },
  "homepage": "https://github.com/Abdulaziz-algharbi/order-pools-backend#readme",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^9.7.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.64.0"
  },
  "lint-staged": {
    "**/*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
